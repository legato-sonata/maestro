# Codespace Configuration
# CODESPACE_CLEANUP_MODE can be "delete" (fully destroy) or "stop" (pause and reuse later)
CODESPACE_CLEANUP_MODE=delete

# GitHub Configuration
GITHUB_USERNAME=your-username
REPOSITORY_NAME=your-repo-name
BRANCH=main
MACHINE_TYPE=standardLinux32gb

# Recording Configuration
TARGET_URL=https://freemusicarchive.org/search/?quicksearch=Violin&search-genre=
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
RECORDING_DURATION_MS=15000
